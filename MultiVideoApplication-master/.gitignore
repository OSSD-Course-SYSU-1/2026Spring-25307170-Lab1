# HarmonyOS 项目 .gitignore 文件

# ==================== HarmonyOS 特定 ====================

# Hvigor 构建缓存和临时文件
.hvigor/
**/.hvigor/
hvigorw
hvigorw.bat

# 构建输出目录
build/
**/build/
.output/
**/.output/

# HarmonyOS 依赖包
oh_modules/
**/oh_modules/

# HarmonyOS 缓存文件
.cache/
**/.cache/
.cxx/
**/.cxx/

# 本地配置文件（包含签名等敏感信息）
local.properties
**/local.properties
*.local.json5

# HarmonyOS IDE 特定文件
.arts/
.codeartsdoer/

# ==================== IDE 配置 ====================

# DevEco Studio / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
*.code-workspace

# ==================== 操作系统文件 ====================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ==================== 日志和临时文件 ====================

# 日志文件
*.log
logs/
*.log.*

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup

# ==================== 测试和覆盖率 ====================

# 测试输出
test-results/
coverage/
.nyc_output/
*.lcov

# ==================== 其他 ====================

# 打包文件
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# 敏感信息文件
*.keystore
*.jks
*.p12
secrets.json
credentials.json

# 文档生成
docs/_build/
site/

# Node.js (如果项目中使用)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json
yarn.lock

# Python (如果项目中使用)
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
ENV/
env/

# Java (如果项目中使用)
*.class
*.jar
*.war
*.ear
.gradle/
target/

# ==================== 保留特定文件 ====================

# 即使上级目录被忽略，也要保留这些文件
!**/oh-package.json5
!**/build-profile.json5
!**/module.json5
!**/app.json5
